# ---------------------------------------------------------------------------
# MirrorFriends environment variables
# Copy to .env.local for local development, and set these in the Convex
# dashboard (Settings -> Environment Variables) for your deployment.
# ---------------------------------------------------------------------------

# OpenAI — used by the Convex AI actions. The mobile app NEVER sees this key.
OPENAI_API_KEY=

# Optional: override the default OpenAI model used for Mirror conversations.
OPENAI_MODEL=gpt-4o-mini

# Clerk — only required if you enable the Clerk auth path (see convex/auth.config.ts).
# Leave blank to use Convex Auth instead.
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# Convex deployment URL — consumed by the mobile app (NOT by the backend).
# e.g. https://your-deployment.convex.cloud
CONVEX_URL=
