# ---------------------------------------------------------------------------
# MirrorFriends environment variables
# Copy to .env.local for local development, and set these in the Convex
# dashboard (Settings -> Environment Variables) for your deployment.
# ---------------------------------------------------------------------------

# OpenAI — used by the Convex AI actions. The mobile app NEVER sees this key.
OPENAI_API_KEY=

# Optional: override the default OpenAI model used for Mirror conversations.
OPENAI_MODEL=gpt-4o-mini

# Convex Auth (@convex-dev/auth). Generate these by running:
#   npx @convex-dev/auth
# which sets JWT_PRIVATE_KEY, JWKS and SITE_URL in your deployment. CONVEX_SITE_URL
# is provided automatically by Convex and is used as the JWT issuer.
JWT_PRIVATE_KEY=
JWKS=
SITE_URL=http://localhost:3000

# Optional OAuth providers for Convex Auth (Apple / Google). Email+password works
# without these.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# Convex deployment URL — consumed by the mobile app (NOT by the backend).
# e.g. https://your-deployment.convex.cloud
CONVEX_URL=
