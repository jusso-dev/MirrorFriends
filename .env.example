# ---------------------------------------------------------------------------
# MirrorFriends environment variables
# Copy to .env.local for local development, and set these in the Convex
# dashboard (Settings -> Environment Variables) for your deployment.
# ---------------------------------------------------------------------------

# OpenAI — used by the Convex AI actions. The browser app NEVER sees this key.
OPENAI_API_KEY=

# Optional: override the default OpenAI model used for Mirror conversations.
OPENAI_MODEL=gpt-5.4-mini

# Optional: context budget for OpenAI hosted web search when Ask My Mirror needs
# current public information. Valid values: low, medium, high.
OPENAI_WEB_SEARCH_CONTEXT_SIZE=medium

# Convex Auth (@convex-dev/auth). Generate these by running:
#   npx @convex-dev/auth
# which sets JWT_PRIVATE_KEY, JWKS and SITE_URL in your deployment. CONVEX_SITE_URL
# is provided automatically by Convex and is used as the JWT issuer.
JWT_PRIVATE_KEY=
JWKS=
SITE_URL=http://localhost:5173

# Invite-only portal access. The configured email can create the first account
# without an invite and will be treated as admin.
ADMIN_EMAIL=
# Optional comma-separated list if you want more than one bootstrap admin.
ADMIN_EMAILS=

# Optional OAuth providers for Convex Auth (Apple / Google). Invite links use
# email/password so the invite code can be checked server-side.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# Convex deployment URL consumed by Vite in the browser.
# This is printed by `npx convex dev`, e.g. https://your-deployment.convex.cloud
VITE_CONVEX_URL=https://your-deployment.convex.cloud
