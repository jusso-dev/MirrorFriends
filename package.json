{
  "name": "mirrorfriends",
  "version": "0.1.0",
  "private": true,
  "description": "MirrorFriends web app and Convex backend — AI Mirrors that talk to each other.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n convex,web -c cyan,green \"npm:dev:convex\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:convex": "convex dev",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "convex deploy",
    "typecheck": "tsc --noEmit",
    "test": "convex run tests:run"
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.93",
    "convex": "^1.40.0",
    "lucide-react": "^0.468.0",
    "openai": "^4.67.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
